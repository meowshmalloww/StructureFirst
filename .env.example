# Bind to localhost by default. For trusted LAN use 0.0.0.0 and set a strong key.
STRUCTUREFIRST_HOST=127.0.0.1
STRUCTUREFIRST_PORT=8787
# STRUCTUREFIRST_ACCESS_KEY=replace-with-a-long-random-key
# STRUCTUREFIRST_COOKIE_SECRET=replace-with-a-separate-long-random-secret

# Optional provider fallbacks. Keys can also be entered in Settings and are then
# encrypted under the local StructureFirst data directory.
# BRAVE_SEARCH_API_KEY=
# GROQ_API_KEY=
# CEREBRAS_API_KEY=
# OPENROUTER_API_KEY=
# NVIDIA_API_KEY=
# STRUCTUREFIRST_BROWSER_EXECUTABLE=C:\Program Files\Google\Chrome\Application\chrome.exe

# Local RTX reconstruction worker.
STRUCTUREFIRST_RECONSTRUCTION_URL=http://127.0.0.1:8010
LUCIDFRAME_ROOT=C:\Users\wenje\Downloads\LucidFrame
# STRUCTUREFIRST_PANORAMA_QUALITY=detail
